# =============================================================================
# Kalshi Trading Data Pipeline — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# --- PostgreSQL (Snowflake Postgres) ---
export PGHOST=your-host.snowflakecomputing.app
export PGPORT=5432
export PGDATABASE=postgres
export PGUSER=snowflake_admin
export PGPASSWORD=<your-password-here>
export PGSSLMODE=require

# --- Snowflake (Snowpipe Streaming / Iceberg) ---
export SNOWFLAKE_PRIVATE_KEY_PATH=keys/rsa_key.p8
export SNOWFLAKE_ACCOUNT=<ORG-ACCOUNT_NAME>
export SNOWFLAKE_USER=KAFKAGUY
export SNOWFLAKE_ROLE=ACCOUNTADMIN
export SNOWFLAKE_DATABASE=KALSHI_DB
export SNOWFLAKE_SCHEMA=STREAMING
export SNOWFLAKE_WAREHOUSE=INGEST

# --- Snowflake CLI (snow) ---
export SNOW_CONNECTION=<your-snow-cli-connection-name>

# --- Kafka (optional, for kafka-produce path) ---
export KAFKA_BROKER=localhost:9092
export KAFKA_TOPIC_PREFIX=kalshi

# --- Snowflake URL (for Kafka Connector deployment) ---
export SNOWFLAKE_URL=<ACCOUNT>.snowflakecomputing.com
